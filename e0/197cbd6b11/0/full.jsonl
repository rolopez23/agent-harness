ll, run evals to test a skill, benchmark skill performance with variance analy…","skillCount":8,"isInitial":true},"type":"attachment","uuid":"a164dfa4-cd12-47a7-a381-14bc635bf403","timestamp":"2026-04-13T06:25:42.505Z","userType":"external","entrypoint":"cli","cwd":"/Users/robertlopez/repos/harness","sessionId":"a38337b2-e7e7-4169-9b2c-4557d8e04c08","version":"2.1.104","gitBranch":"main"}
